# Neon pooled connection (used by the app at runtime)
DATABASE_URL=

# Neon direct/unpooled connection (used by Prisma for migrations/db push)
DATABASE_URL_UNPOOLED=

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Canonical app URL (used for OAuth redirect_uri)
# e.g. https://proofflow.vercel.app or http://localhost:3000
APP_URL=

# Secret used to authenticate Vercel Cron requests
CRON_SECRET=

# Resend API key for email notifications (optional — logs to console if missing)
RESEND_API_KEY=

# From address for notification emails
EMAIL_FROM=
