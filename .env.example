# Neon pooled connection (used by the app at runtime)
DATABASE_URL=

# Neon direct/unpooled connection (used by Prisma for migrations/db push)
DATABASE_URL_UNPOOLED=

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Canonical app URL (used for OAuth redirect_uri)
# e.g. https://proofflow.vercel.app or http://localhost:3000
APP_URL=
