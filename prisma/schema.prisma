generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id                String             @id @default(cuid())
  name              String
  createdAt         DateTime           @default(now())
  integrations      Integration[]
  evidenceSnapshots EvidenceSnapshot[]
  exports           Export[]
  schedules         Schedule[]
}

model Schedule {
  id          String    @id @default(cuid())
  workspaceId String
  type        String
  frequency   String
  lastRunAt   DateTime?
  nextRunAt   DateTime
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, type])
}

model Integration {
  id                String             @id @default(cuid())
  workspaceId       String
  provider          String
  accessToken       String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  evidenceSnapshots EvidenceSnapshot[]

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, provider])
}

model EvidenceSnapshot {
  id            String   @id @default(cuid())
  workspaceId   String
  integrationId String
  type          String
  status        String
  collectedAt   DateTime @default(now())
  data          Json
  createdAt     DateTime @default(now())

  workspace   Workspace               @relation(fields: [workspaceId], references: [id])
  integration Integration             @relation(fields: [integrationId], references: [id])
  exports     Export[]
  controls    EvidenceControlMapping[]
}

model Control {
  id          String                  @id @default(cuid())
  framework   String
  code        String
  name        String
  description String?
  createdAt   DateTime                @default(now())
  mappings    EvidenceControlMapping[]

  @@unique([framework, code])
}

model EvidenceControlMapping {
  id         String @id @default(cuid())
  snapshotId String
  controlId  String

  snapshot EvidenceSnapshot @relation(fields: [snapshotId], references: [id])
  control  Control          @relation(fields: [controlId], references: [id])

  @@unique([snapshotId, controlId])
}

model Export {
  id          String    @id @default(cuid())
  workspaceId String
  snapshotId  String?
  type        String
  status      String
  fileName    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  metadata    Json?

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  snapshot  EvidenceSnapshot? @relation(fields: [snapshotId], references: [id])
}
